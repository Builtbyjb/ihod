{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "server",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-17",
  "env": {
    "staging": {
      "name": "ihod-server-staging",
    },
    "production": {
      "name": "ihod-server-production",
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "acorp-invoice",
          "database_id": "18f70db9-95a9-492b-a230-722cc95baa9c",
          "migrations_dir": "drizzle/migrations",
        },
      ],
      "r2_buckets": [
        {
          "binding": "R2",
          "bucket_name": "acorp-invoice-bucket",
        },
      ],
      "send_email": [
        {
          "name": "SEND_EMAIL",
        },
      ],
    },
    "uat": {
      "name": "ihod-server-uat",
    },
    "dev": {
      "name": "ihod-server-dev",
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "dev-db",
          "database_id": "18f70db9-95a9-492b-a230-722cc95baa9c",
          "migrations_dir": "drizzle/migrations",
        },
      ],
      "r2_buckets": [
        {
          "binding": "R2",
          "bucket_name": "acorp-invoice-bucket",
        },
      ],
      "send_email": [
        {
          "name": "SEND_EMAIL",
        },
      ],
    },
  },
  "dev": {
    "port": 8585,
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1, // optional. default = 1.
  },

  // "compatibility_flags": [
  //   "nodejs_compat"
  // ],
  // "vars": {
  //   "MY_VAR": "my-variable"
  // },
  // "kv_namespaces": [
  //   {
  //     "binding": "MY_KV_NAMESPACE",
  //     "id": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  //   }
  // ],
  // "r2_buckets": [
  //   {
  //     "binding": "MY_BUCKET",
  //     "bucket_name": "my-bucket"
  //   }
  // ],
  // "d1_databases": [
  //   {
  //     "binding": "DB",
  //     "database_name": "my-database",
  //     "database_id": "",
  //   },
  // ],
  // "ai": {
  //   "binding": "AI"
  // },
  // "observability": {
  //   "enabled": true,
  //   "head_sampling_rate": 1
  // }
}
